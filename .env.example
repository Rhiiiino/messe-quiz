# Environment Configuration
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# Node Environment (development, production)
NODE_ENV=production

# Server Port
PORT=3000

# Admin-Panel Zugangsdaten
ADMIN_USERNAME=admin
ADMIN_PASSWORD=IhrSicheresPasswort123!

# Session Secret (für IP-Hashing)
# Generieren mit: openssl rand -base64 32
SESSION_SECRET=generieren-sie-einen-langen-zufaelligen-string-hier
